{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["extensions/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "npm-packages", "dist"]
}
